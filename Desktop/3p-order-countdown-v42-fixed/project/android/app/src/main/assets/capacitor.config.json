{
	"appId": "com.threep.chickenpops",
	"appName": "3P Chicken Pops",
	"webDir": "backend/frontend",
	"server": {
		"url": "https://3p-production.up.railway.app",
		"cleartext": false
	},
	"plugins": {
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"FirebaseAuthentication": {
			"skipNativeAuth": false,
			"providers": [
				"google.com"
			]
		}
	}
}
